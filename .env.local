# ── AI Provider (at least one required) ──────────────────────────────────────
# Groq API key — get free at https://console.groq.com
GROQ_API_KEY=

# Anthropic/Claude API key — fallback if Groq not set
ANTHROPIC_API_KEY=
# ── Optional ──────────────────────────────────────────────────────────────────
# Which Groq model to use (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
